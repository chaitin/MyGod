{
	auto_https disable_redirects
	fallback_sni bootstrap.invalid

	servers {
		protocols h1 h2
	}

	log default {
		output file /var/log/caddy/caddy.log {
			mode 0640
			roll_size 10MiB
			roll_keep 5
			roll_keep_for 720h
		}
	}
}

http://{$PUBLIC_HOSTNAME:localhost} {
	redir https://{$PUBLIC_HOSTNAME:localhost}:{$CLIENT_HTTPS_PORT:443}{uri} 301
}

https://{$PUBLIC_HOSTNAME:localhost} {
	encode zstd gzip

	log {
		output file /var/log/caddy/client-access.log {
			mode 0640
			roll_size 10MiB
			roll_keep 5
			roll_keep_for 720h
		}
	}

	route {
		handle /gateway-healthz {
			respond "ok" 200
		}

		@client_api path /api/client/* /api/app/*
		handle @client_api {
			request_body {
				max_size 201MiB
			}
			reverse_proxy server:20080
		}

		@client_version path /version.json
		header @client_version Cache-Control "no-store, no-cache, must-revalidate"

		@client_document {
			not path /assets/* /version.json
		}
		header @client_document Cache-Control "no-cache"

		handle {
			root * /srv/client
			try_files {path} /index.html
			file_server
		}
	}
}

https://{$PUBLIC_HOSTNAME:localhost}:1443 {
	encode zstd gzip

	log {
		output file /var/log/caddy/admin-access.log {
			mode 0640
			roll_size 10MiB
			roll_keep 5
			roll_keep_for 720h
		}
	}

	route {
		handle /gateway-healthz {
			respond "ok" 200
		}

		handle /api/* {
			request_body {
				max_size 201MiB
			}
			reverse_proxy server:20080
		}

		handle {
			root * /srv/admin
			try_files {path} /index.html
			file_server
		}
	}
}

https://bootstrap.invalid {
	tls /etc/caddy/bootstrap/tls.crt /etc/caddy/bootstrap/tls.key
	respond 421
}
