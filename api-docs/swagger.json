                            "$ref": "#/definitions/httpserver.errorEnvelope"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/httpserver.errorEnvelope"
                        }
                    }
                }
            }
        },
