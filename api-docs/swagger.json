                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/httpserver.createGroupConversationRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "allOf": [
                                {
